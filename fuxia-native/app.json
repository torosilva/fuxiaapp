{
  "expo": {
    "name": "Fuxia Ballerinas",
    "slug": "fuxia-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-brand.png",
    "scheme": "fuxia",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon-brand.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fuxiaballerinas.app",
      "buildNumber": "8",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Usamos tu galería para personalizar la foto de tu tarjeta de lealtad.",
        "NSCameraUsageDescription": "Usamos la cámara para escanear tarjetas de lealtad en tienda y para tomar la foto de tu perfil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fuxiaballerinas.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-brand.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Usamos tu galería para personalizar la foto de tu tarjeta de lealtad."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef3a377e-9d71-4309-a144-c4d18ec1dfa2"
      }
    },
    "owner": "torosilva",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ef3a377e-9d71-4309-a144-c4d18ec1dfa2"
    }
  }
}
